# Copy this file to .env and fill in your own values. Never commit the real .env file.

OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL connection (used for conversation + task history)
DATABASE_URL=postgresql+asyncpg://agent_user:agent_pass@localhost:5432/agent_platform

# ChromaDB storage location (local persistent vector store)
CHROMA_PERSIST_DIR=./data/chroma_store

# Folder the Research Agent indexes documents from
DOCS_DIR=./data/sample_docs

# Agent / LLM tuning — safe to change without touching code
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.0
TOP_K=4
EMBEDDING_MODEL=text-embedding-3-small
